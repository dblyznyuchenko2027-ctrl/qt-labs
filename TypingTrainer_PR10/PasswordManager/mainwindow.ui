<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>900</width><height>580</height></rect>
  </property>
  <property name="windowTitle"><string>Password Manager</string></property>

  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="verticalLayoutMain" stretch="0,1,0">

    <!-- Filter bar -->
    <item>
     <layout class="QHBoxLayout" name="horizontalLayoutFilter">
      <item>
       <widget class="QLabel" name="labelCategory">
        <property name="text"><string>Category:</string></property>
       </widget>
      </item>
      <item>
       <widget class="QComboBox" name="comboBoxCategory">
        <property name="minimumWidth"><number>130</number></property>
        <item><property name="text"><string>All</string></property></item>
       </widget>
      </item>
      <item>
       <spacer name="spacerFilter">
        <property name="orientation"><enum>Qt::Horizontal</enum></property>
        <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
       </spacer>
      </item>
      <item>
       <widget class="QLineEdit" name="lineEditSearch">
        <property name="placeholderText"><string>Search...</string></property>
        <property name="minimumWidth"><number>200</number></property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="pushButtonClear">
        <property name="text"><string>Clear</string></property>
       </widget>
      </item>
     </layout>
    </item>

    <!-- Table + empty-state label stacked -->
    <item>
     <widget class="QStackedWidget" name="stackedWidget">
      <!-- page 0: table -->
      <widget class="QWidget" name="pageTable">
       <layout class="QVBoxLayout" name="vboxTable">
        <property name="margin"><number>0</number></property>
        <item>
         <widget class="QTableView" name="tableViewPasswords">
          <property name="sizePolicy">
           <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
            <horstretch>0</horstretch><verstretch>0</verstretch>
           </sizepolicy>
          </property>
          <property name="alternatingRowColors"><bool>true</bool></property>
          <property name="showGrid"><bool>true</bool></property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="labelEmpty">
          <property name="text"><string>No entries match your search.</string></property>
          <property name="alignment"><set>Qt::AlignCenter</set></property>
          <property name="visible"><bool>false</bool></property>
          <property name="styleSheet"><string>color: gray; font-size: 14px;</string></property>
         </widget>
        </item>
       </layout>
      </widget>
     </widget>
    </item>

    <!-- Status placeholder (real status bar below) -->
   </layout>
  </widget>

  <!-- Menu bar -->
  <widget class="QMenuBar" name="menubar">
   <property name="geometry"><rect><x>0</x><y>0</y><width>900</width><height>22</height></rect></property>
   <widget class="QMenu" name="menuFile">
